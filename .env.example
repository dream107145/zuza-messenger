VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Telegram BOT mode (@BotFather) — shows "BOT" badge ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- Telegram USER mode (your personal account — stealth) ---
# 1. Get api_id + api_hash from https://my.telegram.org → API development tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your-api-hash
# 2. Run: npm run telegram:login — paste the session string here
TELEGRAM_SESSION=
# Only reply in private DMs (recommended). Set true to also reply in groups.
TELEGRAM_REPLY_GROUPS=false
# Optional: comma-separated user IDs to auto-reply to (empty = everyone)
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# Reply speed: instant | fast (default) | normal
TELEGRAM_REPLY_SPEED=fast
# On startup, answer up to this many unread messages per chat
# TELEGRAM_STARTUP_UNREAD_LIMIT=10
# How many recent messages to load as chat context before replying
# TELEGRAM_HISTORY_LIMIT=50
# On startup, preload history for this many eligible contacts (0 = all)
# TELEGRAM_STARTUP_HISTORY_CONTACT_LIMIT=25
# Delay between startup history requests in ms
# TELEGRAM_STARTUP_HISTORY_DELAY_MS=250
# Send a natural follow-up if the other person stays silent after Zuza replies
# TELEGRAM_PROACTIVE_FOLLOWUP=true
# Random silence window before follow-up
# TELEGRAM_PROACTIVE_MIN_MINUTES=45
# TELEGRAM_PROACTIVE_MAX_MINUTES=90
# Max proactive follow-ups per chat until the person replies
# TELEGRAM_PROACTIVE_MAX_PER_CHAT=2

# Crypto tip wallets (optional — defaults are built in)
# CRYPTO_TIP_ETH=0x...
# CRYPTO_TIP_BTC=bc1q...
# CRYPTO_TIP_SOL=...
# CRYPTO_TIP_TRON=T...
# CRYPTO_TIP_BNB=0x...
# CRYPTO_TIP_POLYGON=0x...
# Messages before Zuza may ask for a tip after positive feedback (default 20)
# TIP_MIN_MESSAGES=20
# Approx messages per "week" fallback when calendar days unknown (default 50)
# RELATIONSHIP_MESSAGES_PER_WEEK=50
# Use real calendar days since first message for relationship depth (default true)
# RELATIONSHIP_USE_CALENDAR=true

# SQLite memory server (run npm run memory alongside telegram:user)
# MEMORY_SERVER_URL=http://localhost:11435

# Offline schedule — sleep hours + random long silences
# TELEGRAM_OFFLINE_SCHEDULE=true
# TELEGRAM_SLEEP_HOURS=false
# TELEGRAM_TIMEZONE=Europe/Warsaw
# TELEGRAM_SLEEP_START=23
# TELEGRAM_SLEEP_END=8
# Max random "away" delays per rolling window (default 2 per 2 hours)
# TELEGRAM_RANDOM_SILENCE_WINDOW_HOURS=2
# TELEGRAM_RANDOM_SILENCE_MAX_PER_WINDOW=2
# TELEGRAM_RANDOM_SILENCE_MIN_GAP_MINUTES=45
# TELEGRAM_RANDOM_SILENCE_MIN_MINUTES=2
# TELEGRAM_RANDOM_SILENCE_MAX_MINUTES=5

# Curated photos Zuza can send (no nudes — add casual pics here)
# TELEGRAM_PHOTO_DIR=public/photos
