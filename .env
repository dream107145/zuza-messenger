# Only reply in private DMs (recommended). Set true to also reply in groups.
TELEGRAM_REPLY_GROUPS=false
# Optional: comma-separated user IDs to auto-reply to (empty = everyone)
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# Optional — defaults to http://localhost:11435
# MEMORY_SERVER_URL=http://localhost:11435

# Sleep hours off — short random delays capped at 2 per 2 hours
