{
  "name": "automessage",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:telegram": "tsc -p tsconfig.telegram.json --noEmit",
    "lint": "eslint .",
    "preview": "vite preview",
